---
/**
 * ContactInfoCard - Tarjeta de información de contacto reutilizable
 */
import Icon from './Icon.astro';
import type { ContactInfo } from '../data/therapy';

interface Props {
  items?: ContactInfo[];
  showAvailability?: boolean;
  variant?: 'default' | 'dark';
}

const { 
  items,
  showAvailability = true,
  variant = 'default'
} = Astro.props;

// Importar datos por defecto si no se proporcionan
import { contactInfo as defaultContactInfo } from '../data/therapy';
const contactItems = items || defaultContactInfo;

const isDark = variant === 'dark';
---

<div class="space-y-8">
  <!-- Tarjeta principal -->
  <div class:list={[
    'p-8 lg:p-10 border relative overflow-hidden',
    isDark ? 'bg-ink border-border-strong/30' : 'bg-alabaster border-border-delicate'
  ]}>
    {/* Decorativo */}
    <div class:list={[
      'absolute top-0 right-0 w-32 h-32 rounded-bl-full',
      isDark ? 'bg-gradient-to-bl from-olive/10 to-transparent' : 'bg-gradient-to-bl from-olive/5 to-transparent'
    ]}></div>
    
    <span class:list={[
      'text-label mb-6 block',
      isDark ? 'text-olive' : 'text-olive'
    ]}>Cómo contactarme</span>
    
    <h2 class:list={[
      'font-serif text-2xl sm:text-3xl lg:text-4xl mb-8',
      isDark ? 'text-alabaster' : 'text-ink'
    ]}>
      Estoy aquí
    </h2>
    
    <div class="space-y-6">
      {contactItems.map((item) => (
        <div class="group">
          {item.href ? (
            <a href={item.href} class:list={[
              'flex items-start gap-5 p-4 -mx-4 transition-colors duration-300',
              isDark ? 'hover:bg-ink/50' : 'hover:bg-cream/50'
            ]}>
              <div class:list={[
                'w-12 h-12 rounded-full border flex items-center justify-center shrink-0 transition-all duration-500',
                isDark 
                  ? 'bg-ink border-border-strong/30 text-olive group-hover:bg-olive group-hover:text-alabaster group-hover:border-olive' 
                  : 'bg-cream border-border-delicate text-olive group-hover:bg-olive group-hover:text-alabaster group-hover:border-olive'
              ]}>
                <Icon name={item.icon as any} class="w-5 h-5" />
              </div>
              <div class="pt-1">
                <p class:list={[
                  'text-label-sm mb-1',
                  isDark ? 'text-taupe-light' : 'text-charcoal'
                ]}>{item.label}</p>
                <p class:list={[
                  'font-serif text-xl transition-colors duration-300',
                  isDark 
                    ? 'text-alabaster group-hover:text-olive' 
                    : 'text-ink group-hover:text-olive'
                ]}>{item.value}</p>
                {item.subvalue && (
                  <p class:list={[
                    'text-body-sm mt-1',
                    isDark ? 'text-taupe-light' : 'text-charcoal'
                  ]}>{item.subvalue}</p>
                )}
              </div>
            </a>
          ) : (
            <div class:list={[
              'flex items-start gap-5 p-4 -mx-4',
              isDark ? 'bg-ink/20' : ''
            ]}>
              <div class:list={[
                'w-12 h-12 rounded-full border flex items-center justify-center shrink-0',
                isDark 
                  ? 'bg-ink border-border-strong/30 text-olive' 
                  : 'bg-cream border-border-delicate text-olive'
              ]}>
                <Icon name={item.icon as any} class="w-5 h-5" />
              </div>
              <div class="pt-1">
                <p class:list={[
                  'text-label-sm mb-1',
                  isDark ? 'text-taupe-light' : 'text-charcoal'
                ]}>{item.label}</p>
                <p class:list={[
                  'font-serif text-xl',
                  isDark ? 'text-alabaster' : 'text-ink'
                ]}>{item.value}</p>
                {item.subvalue && (
                  <p class:list={[
                    'text-body-sm mt-1',
                    isDark ? 'text-taupe-light' : 'text-charcoal'
                  ]}>{item.subvalue}</p>
                )}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
  
  <!-- Disponibilidad -->
  {showAvailability && (
    <div class="bg-charcoal p-8 lg:p-10 text-alabaster relative overflow-hidden">
      <div class="absolute -bottom-8 -right-8 w-32 h-32 rounded-full bg-olive/20 blur-2xl"></div>
      
      <div class="relative z-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-olive opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-olive"></span>
          </span>
          <span class="text-label text-olive">Disponible</span>
        </div>
        <p class="text-body-sm sm:text-body text-taupe-light mb-4">
          De lunes a viernes, presencial en Córdoba y online. La primera consulta es sin compromiso: solo hablamos y vemos si encajamos.
        </p>
        <div class="flex items-center gap-4 text-label-sm text-alabaster/60">
          <div class="flex items-center gap-2">
            <Icon name="clock" class="w-4 h-4" />
            <span>Sesiones de 50 minutos</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <span>Presencial y Online</span>
          </div>
        </div>
      </div>
    </div>
  )}
</div>
